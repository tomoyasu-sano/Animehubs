# Database
DATABASE_URL=./data/animehubs.db

# Resend (メール送信)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@example.com

# Admin認証
# ハッシュ生成: node -e "console.log(require('bcryptjs').hashSync('yourpassword', 10))"
# 重要: $ を \$ にエスケープすること（例: $2b$10$... → \$2b\$10\$...）
ADMIN_PASSWORD_HASH=\$2a\$10\$your-bcrypt-hash-here
JWT_SECRET=your-jwt-secret-here

# Instagram
INSTAGRAM_URL=https://www.instagram.com/your_account_here
