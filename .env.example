# Database
DATABASE_URL=./data/animehubs.db

# Resend (メール送信)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@example.com

# Admin
JWT_SECRET=your-jwt-secret-here
# Generate hash: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
ADMIN_PASSWORD_HASH=$2a$10$your-bcrypt-hash-here

# Instagram
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/your_account_here
